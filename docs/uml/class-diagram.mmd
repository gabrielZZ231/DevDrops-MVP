%%{init: {"theme": "base", "themeVariables": {
  "primaryColor": "#eef2ff",
  "primaryBorderColor": "#4f46e5",
  "primaryTextColor": "#0f172a",
  "lineColor": "#334155",
  "tertiaryColor": "#f8fafc",
  "fontFamily": "Segoe UI"
}}}%%
classDiagram
  direction LR

  class Usuario {
    +Long id
    +String nome
    +String email
    +String senha
  }

  class Drop {
    +Long id
    +String titulo
    +String conteudo
    +Date dataPublicacao
  }

  class DropDAO {
    +void salvar(Drop drop)
    +List~Drop~ listar()
  }

  class JPAUtil {
    +EntityManager getEntityManager()
  }

  Usuario "1" <-- "0..*" Drop : autor
  DropDAO ..> Drop : persiste
  DropDAO ..> JPAUtil : obtem EntityManager

  classDef entity fill:#eef2ff,stroke:#4f46e5,stroke-width:1.5px,color:#0f172a
  classDef service fill:#f8fafc,stroke:#1e293b,stroke-width:1.25px,color:#0f172a

  class Usuario entity
  class Drop entity
  class DropDAO service
  class JPAUtil service
