# DevDrops - variáveis locais (NÃO sobe pro Git)
# Dica Windows: use caminhos com barra única (C:\servidores\...) ou com '/' (C:/servidores/...).

DEV_DROPS_DB_HOST=localhost
DEV_DROPS_DB_PORT=5432
DEV_DROPS_DB_NAME=devdrops_db
DEV_DROPS_DB_USER=postgres
DEV_DROPS_DB_PASSWORD=change-me


# Exemplo (opcional)
JBOSS_HOME=C:\servidores\jboss-5.1.0.GA\jboss-5.1.0.GA

# Obrigatório para rodar o JBoss 5.1: aponte para um JDK 7 (precisa existir bin\java.exe)
# Ex: C:\Program Files\Java\jdk1.7.0_80
JDK7_HOME=

# Recomendado para compilar com -source/-target 1.7: aponte para um JDK 8 (bin\javac.exe)
# Alternativa: configurar ~/.m2/toolchains.xml e usar o profile Maven -Ptoolchain
# Ex: C:\Program Files\Java\jdk1.8.0_202
JDK8_HOME=
